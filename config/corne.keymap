#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/pointing.h>

#define DEFAULT 0
#define SYMB    1
#define ARROW   2
#define MOUSE   3
#define MEDIA   4
#define NUM     5
#define ADJUST  6
#define QWERTY  7

/ {
    behaviors {
        hm: homerow_mod {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <150>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&kp>;
            // apparently deprecated
            // global-quick-tap;
            require-prior-idle-ms = <150>; // ← new syntax, explicit timing
        };

        sc_lspo: space_cadet_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ==========================================
        // Layer 0: DEFAULT
        // ==========================================
        default_layer {
            bindings = <
 // ╭──────────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮   ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮
      &lt MEDIA DEL      &kp Q          &kp W          &kp E          &kp R          &kp T              &kp Y          &kp U          &kp I          &kp O          &kp P          &kp BSPC
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &hm LGUI TAB       &hm LSHFT A    &kp S          &kp D          &lt ARROW F    &kp G              &kp H          &kp J          &kp K          &kp L          &hm RSHFT SEMI &hm LGUI SQT
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &sc_lspo LSHFT LPAR &hm LCTRL Z   &hm LALT X     &kp C          &lt MOUSE V    &kp B              &kp N          &kp M          &kp COMMA      &hm RALT DOT   &hm RCTRL FSLH &sc_lspo RSHFT RPAR
 // ╰──────────────────┴──────────────┴──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┴──────────────┴──────────────╯
                                                       &hm LCTRL ESC  &lt NUM DEL    &lt SYMB SPACE     &lt SYMB BSPC  &hm LS(LGUI) RET &lt ADJUST ESC
 //                                                  ╰──────────────┴──────────────┴──────────────╯   ╰──────────────┴──────────────┴──────────────╯
            >;
        };

        // ==========================================
        // Layer 1: SYMB
        // ==========================================
        symb_layer {
            bindings = <
 // ╭──────────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮   ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮
      &trans             &kp QMARK      &kp CARET      &kp PRCNT      &kp HASH       &kp ASTRK          &kp EQUAL      &kp LBRC       &kp RBRC       &kp AT         &kp EXCL       &trans
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &trans             &kp BSLH       &kp AMPS       &kp LBKT       &kp RBKT       &kp MINUS          &kp UNDER      &kp LPAR       &kp RPAR       &kp DLLR       &kp COLON      &kp DQT
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &trans             &kp SQT        &kp COMMA      &kp DOT        &kp GRAVE      &kp PLUS           &kp TILDE      &kp PIPE       &kp LT         &kp GT         &kp FSLH       &trans
 // ╰──────────────────┴──────────────┴──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┴──────────────┴──────────────╯
                                                       &trans         &trans         &kp SPACE           &kp SPACE      &trans         &trans
 //                                                  ╰──────────────┴──────────────┴──────────────╯   ╰──────────────┴──────────────┴──────────────╯
            >;
        };

        // ==========================================
        // Layer 2: ARROW (no repeat key, caps word enabled)
        // ==========================================
        arrow_layer {
            bindings = <
 // ╭──────────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮   ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮
      &trans             &trans         &trans         &trans         &trans         &trans              &trans         &kp HOME       &kp PG_DN      &kp PG_UP      &kp END        &trans
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &trans             &trans         &trans         &trans         &trans         &trans              &trans         &kp LEFT       &kp DOWN       &kp UP         &kp RIGHT      &caps_word
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &trans             &trans         &trans         &trans         &trans         &trans              &kp INS        &kp CAPS       &trans         &trans         &trans         &trans
 // ╰──────────────────┴──────────────┴──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┴──────────────┴──────────────╯
                                                       &trans         &trans         &trans              &trans         &trans         &trans
 //                                                  ╰──────────────┴──────────────┴──────────────╯   ╰──────────────┴──────────────┴──────────────╯
            >;
        };

        // ==========================================
        // Layer 3: MOUSE (requires CONFIG_ZMK_POINTING=y)
        // ==========================================
        mouse_layer {
            bindings = <
 // ╭──────────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮   ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮
      &trans             &trans         &trans         &trans         &trans         &trans              &trans         &msc SCRL_LEFT &msc SCRL_DOWN &msc SCRL_UP   &msc SCRL_RIGHT &trans
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &trans             &trans         &trans         &trans         &trans         &trans              &trans         &mmv MOVE_LEFT &mmv MOVE_DOWN &mmv MOVE_UP   &mmv MOVE_RIGHT &trans
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &trans             &trans         &trans         &trans         &trans         &trans              &trans         &trans         &trans         &trans         &trans         &trans
 // ╰──────────────────┴──────────────┴──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┴──────────────┴──────────────╯
                                                       &trans         &trans         &mkp RCLK           &mkp LCLK      &mkp MCLK      &trans
 //                                                  ╰──────────────┴──────────────┴──────────────╯   ╰──────────────┴──────────────┴──────────────╯
            >;
        };

        // ==========================================
        // Layer 4: MEDIA
        // ==========================================
        media_layer {
            bindings = <
 // ╭──────────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮   ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮
      &none              &kp F1         &kp F2         &kp F3         &kp F4         &kp F5              &kp F6         &kp F7         &kp F8         &kp F9         &kp F10        &none
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &none              &none          &none          &none          &none          &kp F11             &kp F12        &kp C_PREV     &kp C_STOP     &kp C_PP       &kp C_NEXT     &none
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├────────���─────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &none              &none          &none          &none          &none          &none               &none          &none          &none          &none          &none          &kp C_MUTE
 // ╰──────────────────┴──────────────┴──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┴──────────────┴──────────────╯
                                                       &none          &none          &none               &none          &kp C_VOL_DN   &kp C_VOL_UP
 //                                                  ╰──────────────┴──────────────┴──────────────╯   ╰──────────────┴──────────────┴──────────────╯
            >;
        };

        // ==========================================
        // Layer 5: NUM
        // ==========================================
        num_layer {
            bindings = <
 // ╭──────────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮   ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮
      &trans             &kp QMARK      &kp CARET      &kp PRCNT      &kp HASH       &kp ASTRK          &kp EQUAL      &kp N7         &kp N8         &kp N9         &kp EXCL       &trans
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &trans             &kp FSLH       &kp AMPS       &kp LBKT       &kp RBKT       &kp MINUS          &kp UNDER      &kp N4         &kp N5         &kp N6         &kp COLON      &kp DQT
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &trans             &kp SQT        &kp COMMA      &kp DOT        &kp GRAVE      &kp PLUS           &kp N0         &kp N1         &kp N2         &kp N3         &trans         &trans
 // ╰────────���─────────┴──────────────┴──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┴──────────────┴──────────────╯
                                                       &trans         &trans         &trans              &kp SPACE      &kp N0         &trans
 //                                                  ╰──────────────┴──────────────┴──────────────╯   ╰──────────────┴──────────────┴──────────────╯
            >;
        };

        // ==========================================
        // Layer 6: ADJUST (Bluetooth + External Power)
        // ==========================================
        adjust_layer {
            bindings = <
 // ╭──────────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮   ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮
      &bootloader        &none          &none          &none          &none          &none               &none          &none          &none          &none          &none          &bootloader
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &bt BT_CLR         &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2   &bt BT_SEL 3   &bt BT_SEL 4      &none          &none          &none          &none          &none          &none
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &bt BT_CLR_ALL     &bt BT_PRV     &bt BT_NXT     &none          &none     &ext_power EP_TOG      &none          &none          &none          &none          &none          &none
 // ╰──────────────────┴──────────────┴──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┴──────────────┴──────────────╯
                                                       &to QWERTY     &none          &none               &none          &none          &none
 //                                                  ╰──────────────┴──────────────┴──────────────╯   ╰──────────────┴──────────────┴──────────────╯
            >;
        };

        // ==========================================
        // Layer 7: QWERTY
        // ==========================================
        qwerty_layer {
            bindings = <
 // ╭──────────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮   ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮
      &kp DEL            &kp Q          &kp W          &kp E          &kp R          &kp T               &kp Y          &kp U          &kp I          &kp O          &kp P          &to DEFAULT
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &kp TAB            &kp A          &kp S          &kp D          &kp F          &kp G               &kp H          &kp J          &kp K          &kp L          &kp SEMI       &hm LGUI SQT
 // ├──────────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤
      &kp LSHFT          &kp Z          &kp X          &kp C          &kp V          &kp B               &kp N          &kp M          &kp COMMA      &kp DOT        &kp FSLH       &kp RSHFT
 // ╰──────────────────┴──────────────┴──────────────┼──────────────┼──────────────┼──────────────┤   ├──────────────┼──────────────┼──────────────┼──────────────┴──────────────┴──────────────╯
                                                       &kp LCTRL      &kp SPACE      &kp RET             &kp BSPC       &kp RET        &kp ESC
 //                                                  ╰──────────────┴──────────────┴──────────────╯   ╰──────────────┴──────────────┴──────────────╯
            >;
        };
    };
};